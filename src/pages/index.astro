---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Nav -->
  <nav class="nav" id="nav">
    <div class="nav-inner">
      <a href="/" class="logo">
        <img src="/images/peach2.png" alt="Grameow" class="logo-icon" />
        <span class="logo-text">Grameow</span>
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero" data-nav-bg="surface">
    <div class="hero-inner">
      <div class="hero-text">
        <h1 class="hero-title">
          영어 문법,<br />
          <span class="highlight-peach">그래뮤</span>와 함께<br />
          쉽고 재미있게
        </h1>
        <p class="hero-desc">
          영어의 기본이 되는 문법,<br />
          탄탄한 기초 위에 세우는 진짜 영어 실력,<br />
          그래뮤와 시작하세요.
        </p>
        <div class="hero-cta desktop-only">
          <a href="#download" class="btn-primary">지금 시작하기</a>
        </div>
      </div>
      <div class="hero-cta mobile-only">
        <a href="#download" class="btn-primary">지금 시작하기</a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features" data-nav-bg="bg">
    <!-- Feature 1: 커리큘럼 -->
    <div class="feature-row">
      <div class="feature-image">
        <div class="phone-mockup"><img src="/images/demo-curriculum.png" alt="커리큘럼 화면" class="phone-screen" /></div>
      </div>
      <div class="feature-text">
        <span class="feature-badge badge-blue">체계적인 커리큘럼</span>
        <h2 class="feature-title">초급부터 고급까지<br />단계별 맞춤 학습</h2>
        <p class="feature-desc">
          18개 챕터, 100개 이상의 레슨으로 구성된 체계적인 커리큘럼.
          내 수준에 맞는 레벨에서 시작하세요.
        </p>
      </div>
    </div>

    <!-- Feature 2: 수업 -->
    <div class="feature-row reverse">
      <div class="feature-image">
        <div class="phone-mockup"><img src="/images/demo-class.png" alt="수업 화면" class="phone-screen" /></div>
      </div>
      <div class="feature-text">
        <span class="feature-badge badge-green">알기 쉬운 수업</span>
        <h2 class="feature-title">핵심만 담은<br />간결한 문법 설명</h2>
        <p class="feature-desc">
          어렵고 복잡한 문법도 한눈에 이해할 수 있도록
          핵심 내용을 카드 형태로 정리했습니다.
        </p>
      </div>
    </div>

    <!-- Feature 3: 예문 -->
    <div class="feature-row">
      <div class="feature-image">
        <div class="phone-mockup"><img src="/images/demo-example.png" alt="예문 화면" class="phone-screen" /></div>
      </div>
      <div class="feature-text">
        <span class="feature-badge badge-peach">실전 예문</span>
        <h2 class="feature-title">실생활에서 바로 쓰는<br />예문과 해설</h2>
        <p class="feature-desc">
          배운 문법이 실제로 어떻게 쓰이는지
          풍부한 예문과 상세한 해설로 확인하세요.
        </p>
      </div>
    </div>

    <!-- Feature 4: 퀴즈 -->
    <div class="feature-row reverse">
      <div class="feature-image">
        <div class="phone-mockup"><img src="/images/demo-quiz.png" alt="퀴즈 화면" class="phone-screen" /></div>
      </div>
      <div class="feature-text">
        <span class="feature-badge badge-blue">다양한 퀴즈</span>
        <h2 class="feature-title">4지선다, 빈칸 채우기,<br />순서 배열까지</h2>
        <p class="feature-desc">
          다양한 유형의 퀴즈로 문법을 확실하게 익히세요.
          틀려도 괜찮아요, 설명과 함께 다시 배울 수 있습니다.
        </p>
      </div>
    </div>

    <!-- Feature 5: 진행도 -->
    <div class="feature-row">
      <div class="feature-image">
        <div class="phone-mockup"><img src="/images/demo-home.png" alt="결과 화면" class="phone-screen" /></div>
      </div>
      <div class="feature-text">
        <span class="feature-badge badge-green">학습 기록</span>
        <h2 class="feature-title">매일의 성장을<br />한눈에 확인</h2>
        <p class="feature-desc">
          학습 이력과 정답률을 추적하고,
          연속 학습 스트릭으로 꾸준한 습관을 만들어보세요.
        </p>
      </div>
    </div>
  </section>

  <!-- Levels -->
  <section class="levels" data-nav-bg="surface">
    <div class="levels-inner">
      <h2 class="section-title">나에게 맞는 레벨로 시작하세요</h2>
      <div class="level-accordion" id="level-accordion">
        <div class="level-card" data-level="BEGINNER" data-color="#6ba3d6" style="border: 1px solid #6ba3d630;">
          <div class="level-card-header" style="background: #6ba3d615;">
            <h3 class="level-name">🌱 초급</h3>
            <p class="level-desc">be동사, 현재시제 등 기초 문법부터 차근차근</p>
          </div>
          <div class="level-chapters"></div>
        </div>
        <div class="level-card" data-level="INTERMEDIATE" data-color="#7eb87e" style="border: 1px solid #7eb87e30;">
          <div class="level-card-header" style="background: #7eb87e15;">
            <h3 class="level-name">📚 중급</h3>
            <p class="level-desc">현재완료, 관계대명사 등 실용 문법을 익히기</p>
          </div>
          <div class="level-chapters"></div>
        </div>
        <div class="level-card" data-level="ADVANCED" data-color="#e8917f" style="border: 1px solid #e8917f30;">
          <div class="level-card-header" style="background: #e8917f15;">
            <h3 class="level-name">🎓 고급</h3>
            <p class="level-desc">가정법, 분사구문 등 고급 표현까지 완성</p>
          </div>
          <div class="level-chapters"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Download CTA -->
  <section class="download" id="download" data-nav-bg="bg">
    <div class="download-inner">
      <img src="/images/app-icon.png" alt="Grameow" class="download-mascot" />
      <h2 class="download-title">지금 바로 시작하세요</h2>
      <p class="download-desc">무료로 다운로드하고 오늘부터 영어 문법 공부를 시작하세요.</p>
      <div class="download-buttons">
        <a href="#" class="store-btn">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          App Store (TestFlight)
        </a>
        <a href="https://github.com/piggmme/grameow/releases/download/v0.1.0/app-release.apk" class="store-btn" download>
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/></svg>
          Android 다운로드
        </a>
      </div>
      <p class="download-note">iOS는 TestFlight에서, Android는 APK 직접 설치로 이용 가능합니다.</p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-logo">
        <img src="/images/peach2.png" alt="Grameow" class="footer-icon" />
        <span>Grameow</span>
      </div>
      <p class="footer-copy">&copy; 2026 Grameow. All rights reserved.</p>
    </div>
  </footer>
<script>
  // --- Curriculum Accordion ---
  const LEVEL_COLORS: Record<string, string> = {
    BEGINNER: '#6ba3d6',
    INTERMEDIATE: '#7eb87e',
    ADVANCED: '#e8917f',
  };

  interface Chapter {
    id: number;
    title: string;
    level: string;
    stages: { lessons: { id: number }[] }[];
  }

  const levelCards = document.querySelectorAll<HTMLElement>('.level-card');

  // API에서 목차 로드
  async function loadCurriculum() {
    try {
      const res = await fetch('https://grameow-server-production.up.railway.app/curriculum/full');
      const chapters: Chapter[] = await res.json();

      const grouped: Record<string, Chapter[]> = {};
      for (const ch of chapters) {
        if (!grouped[ch.level]) grouped[ch.level] = [];
        grouped[ch.level].push(ch);
      }

      levelCards?.forEach(card => {
        const level = card.dataset.level || '';
        const color = LEVEL_COLORS[level] || '#999';
        const levelChapters = grouped[level] || [];
        const chaptersEl = card.querySelector('.level-chapters')!;

        chaptersEl.innerHTML = `
          <div class="level-chapters-inner">
            ${levelChapters.map(ch => {
              const lessonCount = ch.stages.reduce((s, st) => s + st.lessons.length, 0);
              return `
                <div class="chapter-row">
                  <div class="chapter-title">${ch.title}</div>
                  <div class="chapter-lessons">${lessonCount}개 레슨</div>
                </div>
              `;
            }).join('')}
          </div>
        `;
      });
    } catch {
      // 실패 시 카드 UI 유지, 아코디언 클릭해도 빈 상태
    }
  }

  loadCurriculum();

  // --- Nav background ---
  const nav = document.getElementById('nav');
  const sections = document.querySelectorAll('[data-nav-bg]');

  const colors: Record<string, string> = {
    surface: 'rgba(255, 255, 255, 0.85)',
    bg: 'rgba(247, 246, 243, 0.85)',
  };

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const bg = (entry.target as HTMLElement).dataset.navBg || 'surface';
          nav!.style.background = colors[bg];
        }
      }
    },
    { rootMargin: '-1px 0px -100% 0px', threshold: 0 },
  );

  sections.forEach((s) => observer.observe(s));
</script>
</Layout>

<style>
  /* Nav */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: background 0.3s ease;
    scroll-snap-align: start;
  }

  .nav-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-text);
  }

  .logo-icon {
    width: 36px;
    height: 36px;
    object-fit: contain;
  }

  .logo-text {
    font-size: 20px;
    font-weight: 800;
  }

  /* Hero */
  .hero {
    padding: 120px 24px 80px;
    overflow: hidden;
    background: var(--color-surface) url('/images/main-cat.png') no-repeat right bottom;
    background-size: 800px auto;
    scroll-snap-align: start;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-inner {
    max-width: 960px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 60px;
  }

  .hero-text {
    flex: 1;
  }

  .hero-title {
    font-size: 48px;
    font-weight: 800;
    line-height: 1.3;
    letter-spacing: -1px;
    margin-bottom: 20px;
  }

  .highlight-peach {
    color: var(--color-level-advanced);
  }

  .hero-desc {
    font-size: 18px;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .hero-cta {
    margin-top: 32px;
  }

  .mobile-only {
    display: none;
  }

  .btn-primary {
    display: inline-block;
    background: var(--color-cta);
    color: #fff;
    padding: 16px 40px;
    border-radius: 16px;
    font-size: 18px;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(61, 57, 52, 0.2);
  }

  .hero-image {
    flex: 0 0 auto;
  }

  .hero-image img {
    width: 340px;
    height: 340px;
    object-fit: contain;
  }

  /* Features */
  .features {
    padding: 104px 24px 80px;
    scroll-snap-align: start;
  }

  .feature-row {
    max-width: 960px;
    margin: 0 auto 80px;
    display: flex;
    align-items: center;
    gap: 80px;
  }

  .feature-row.reverse {
    flex-direction: row-reverse;
  }

  .feature-image {
    flex: 0 0 auto;
  }

  .feature-image img {
    width: 280px;
    height: 280px;
    object-fit: contain;
  }

  .feature-image .phone-mockup {
    width: 300px;
    background: #1a1a1a;
    border-radius: 46px;
    padding: 7px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
    overflow: hidden;
  }

  .phone-mockup .phone-screen {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 40px;
    aspect-ratio: 1206 / 2622;
    object-fit: cover;
  }

  .feature-text {
    flex: 1;
  }

  .feature-badge {
    display: inline-block;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .badge-blue {
    background: #6ba3d620;
    color: var(--color-level-beginner);
  }

  .badge-green {
    background: #7eb87e20;
    color: var(--color-level-intermediate);
  }

  .badge-peach {
    background: #e8917f20;
    color: var(--color-level-advanced);
  }

  .feature-title {
    font-size: 32px;
    font-weight: 800;
    line-height: 1.35;
    margin-bottom: 16px;
  }

  .feature-desc {
    font-size: 17px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 380px;
  }

  /* Levels */
  .levels {
    padding: 80px 24px;
    background: var(--color-surface);
    scroll-snap-align: start;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .levels-inner {
    max-width: 960px;
    width: 100%;
    margin: 0 auto;
    text-align: center;
  }

  .section-title {
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 48px;
  }

</style>

<style is:global>
  /* Fallback cards */
  .level-cards {
    display: flex;
    gap: 24px;
    justify-content: center;
  }

  .level-card {
    flex: 1;
    border-radius: 20px;
  }

  .level-card .level-dot {
    margin: 0 auto 16px;
  }

  .level-name {
    font-size: 20px;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .level-desc {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* Accordion */
  .level-accordion {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  @media (max-width: 768px) {
    .level-accordion {
      flex-direction: column;
      align-items: center;
    }

    .level-card {
      width: 100%;
      max-width: 400px;
    }

  }

  .level-card {
    flex: 1;
    border-radius: 20px;
    overflow: hidden;
    background: var(--color-surface);
  }

  .level-card-header {
    padding: 20px;
  }

  .level-name {
    font-size: 24px;
    font-weight: 800;
    margin-bottom: 2px;
    text-align: left;
  }

  .level-desc {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.5;
    word-break: keep-all;
    text-align: left;
  }



  .level-chapters {
    padding: 12px 16px 14px;
    text-align: left;
  }


  .chapter-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 4px 0;
  }

  .chapter-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .chapter-lessons {
    font-size: 13px;
    color: var(--color-text-tertiary);
    flex-shrink: 0;
    margin-left: 8px;
  }
</style>

<style>
  /* Download CTA */
  .download {
    padding: 100px 24px;
    text-align: center;
    scroll-snap-align: start;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .download-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .download-mascot {
    width: 120px;
    height: 120px;
    object-fit: contain;
    margin-bottom: 24px;
    border-radius: 24px;
  }

  .download-title {
    font-size: 36px;
    font-weight: 800;
    margin-bottom: 12px;
  }

  .download-desc {
    font-size: 17px;
    color: var(--color-text-secondary);
    margin-bottom: 32px;
  }

  .download-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-bottom: 16px;
  }

  .store-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-cta);
    color: #fff;
    padding: 14px 28px;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s;
  }

  .store-btn:hover {
    transform: translateY(-2px);
  }

  .download-note {
    font-size: 14px;
    color: var(--color-text-tertiary);
  }

  /* Footer */
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 32px 24px;
    scroll-snap-align: end;
  }

  .footer-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 800;
    font-size: 16px;
  }

  .footer-icon {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .footer-copy {
    font-size: 14px;
    color: var(--color-text-tertiary);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-inner {
      flex-direction: column;
      text-align: left;
      align-items: flex-start;
      gap: 24px;
    }

    .hero-cta {
      margin-top: 0;
    }

    .hero-cta .btn-primary {
      padding: 12px 28px;
      font-size: 15px;
      border-radius: 12px;
    }

    .desktop-only {
      display: none;
    }

    .mobile-only {
      display: block;
    }

    .hero-title {
      font-size: 32px;
    }

    .hero {
      background-image: url('/images/main-cat-mobile.png') !important;
      background-size: 90vw auto !important;
      align-items: flex-start;
      justify-content: flex-start;
    }

    .hero-desc {
      font-size: 16px;
    }

    .feature-row,
    .feature-row.reverse {
      flex-direction: column-reverse;
      gap: 32px;
      text-align: center;
    }

    .feature-image img {
      width: 200px;
      height: 200px;
    }

    .feature-image .phone-mockup {
      width: 240px;
      border-radius: 38px;
    }

    .phone-mockup .phone-screen {
      border-radius: 32px;
    }

    .feature-title {
      font-size: 24px;
    }

    .level-cards {
      flex-direction: column;
      align-items: center;
