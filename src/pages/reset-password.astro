---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="reset-page">
    <div class="reset-card">
      <img src="/images/peach2.png" alt="Grameow" class="reset-logo" />
      <h1 class="reset-title">비밀번호 재설정</h1>
      <p id="reset-desc" class="reset-desc">새로 사용할 비밀번호를 입력해주세요.</p>

      <form id="reset-form" class="reset-form">
        <label class="reset-label">
          <span>새 비밀번호 (8자 이상)</span>
          <input type="password" id="new-password" minlength="8" required autocomplete="new-password" />
        </label>
        <label class="reset-label">
          <span>비밀번호 확인</span>
          <input type="password" id="confirm-password" minlength="8" required autocomplete="new-password" />
        </label>
        <p id="error-msg" class="reset-error" hidden></p>
        <button type="submit" id="submit-btn" class="reset-button">비밀번호 변경</button>
      </form>

      <div id="success-view" class="reset-success" hidden>
        <p>비밀번호가 변경되었어요.</p>
        <p class="reset-success-sub">앱으로 돌아가서 새 비밀번호로 로그인해주세요.</p>
      </div>
    </div>
  </main>
</Layout>

<style>
  .reset-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: #faf7f2;
  }
  .reset-card {
    width: 100%;
    max-width: 420px;
    background: #fff;
    border-radius: 16px;
    padding: 32px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    text-align: center;
  }
  .reset-logo {
    width: 64px;
    height: 64px;
    margin-bottom: 16px;
  }
  .reset-title {
    font-size: 22px;
    font-weight: 700;
    margin: 0 0 8px;
    color: #1f2937;
  }
  .reset-desc {
    font-size: 14px;
    color: #6b7280;
    margin: 0 0 24px;
  }
  .reset-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: left;
  }
  .reset-label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 13px;
    color: #374151;
    font-weight: 500;
  }
  .reset-label input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    font-size: 15px;
    box-sizing: border-box;
  }
  .reset-label input:focus {
    outline: none;
    border-color: #5d9d6b;
  }
  .reset-error {
    color: #dc2626;
    font-size: 13px;
    margin: 0;
  }
  .reset-button {
    margin-top: 8px;
    padding: 14px;
    background: #5d9d6b;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
  }
  .reset-button:disabled {
    background: #d1d5db;
    cursor: not-allowed;
  }
  .reset-success {
    margin-top: 8px;
    color: #1f2937;
    font-size: 15px;
    line-height: 1.6;
  }
  .reset-success-sub {
    margin-top: 8px;
    color: #6b7280;
    font-size: 14px;
  }
</style>

<script>
  const API_BASE =
    window.location.hostname === 'localhost'
      ? 'http://localhost:3030'
      : 'https://grameow-server-production.up.railway.app';

  const params = new URLSearchParams(window.location.search);
  const token = params.get('token') ?? '';
  const uidRaw = params.get('uid') ?? '';
  const userId = parseInt(uidRaw, 10);

  const form = document.getElementById('reset-form') as HTMLFormElement;
  const newPwInput = document.getElementById('new-password') as HTMLInputElement;
  const confirmInput = document.getElementById('confirm-password') as HTMLInputElement;
  const errorMsg = document.getElementById('error-msg') as HTMLParagraphElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successView = document.getElementById('success-view') as HTMLDivElement;
  const resetDesc = document.getElementById('reset-desc') as HTMLParagraphElement;

  function showError(msg: string) {
    errorMsg.textContent = msg;
    errorMsg.hidden = false;
  }
  function hideError() {
    errorMsg.hidden = true;
  }

  if (!token || !userId || Number.isNaN(userId)) {
    showError('잘못된 링크입니다. 재설정 메일에서 다시 시도해주세요.');
    submitBtn.disabled = true;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    const newPassword = newPwInput.value;
    const confirm = confirmInput.value;

    if (newPassword.length < 8) {
      showError('비밀번호는 8자 이상이어야 해요.');
      return;
    }
    if (newPassword !== confirm) {
      showError('비밀번호가 일치하지 않아요.');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = '변경 중...';

    try {
      const res = await fetch(`${API_BASE}/auth/reset-password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, token, newPassword }),
      });

      if (!res.ok) {
        const body = await res.json().catch(() => ({}));
        showError(body?.message ?? '비밀번호 변경에 실패했어요. 링크가 만료됐을 수 있어요.');
        submitBtn.disabled = false;
        submitBtn.textContent = '비밀번호 변경';
        return;
      }

      form.style.display = 'none';
      resetDesc.style.display = 'none';
      successView.style.display = 'block';
    } catch {
      showError('네트워크 오류가 발생했어요. 잠시 후 다시 시도해주세요.');
      submitBtn.disabled = false;
      submitBtn.textContent = '비밀번호 변경';
    }
  });
</script>
